HOST=your-oracle-host.example.com
PORT=1521
SERVICE_NAME=your_service_name
USERNAME=your_username
PASSWORD=your_password

# Optional: set if your database requires Oracle Client / thick mode.
# ORACLE_CLIENT_LIB_DIR=/path/to/instantclient

# OpenAI / LangGraph agent
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=openai:gpt-4.1-mini

# Table the agent should focus on. Leave blank to let the agent list/discover tables.
TARGET_TABLE=
TARGET_SCHEMA=
MAX_ROWS=50

# Oracle MCP toolkit.
# Option A: stdio mode. Build oracle/mcp's oracle-db-mcp-java-toolkit jar and set this path.
ORACLE_MCP_TOOLKIT_JAR=/absolute/path/to/oracle-db-mcp-toolkit-1.0.0.jar
JAVA_BIN=java

# Option B: HTTP mode. If set, the agent connects to this URL instead of spawning Java.
# ORACLE_MCP_SERVER_URL=http://localhost:45450/mcp
# ORACLE_MCP_AUTH_TOKEN=

# Keep this read-only by default. Add "table" only if you accept its create/drop actions.
ORACLE_MCP_TOOLS=read-query,db-ping,explain-plan,list-tools
